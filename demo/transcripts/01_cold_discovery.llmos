# =============================================================================
# Beat 1: Cold discovery
#
# The model is told nothing about llmos. It uses `help` to list primitives,
# then `describe` on each one to learn their schemas. At the end it has a
# complete, self-discovered model of the machine's capability surface -
# derived entirely from introspection, with zero training data about llmos.
# =============================================================================

help

# "primitives=help,describe,cpu.vendor,cpu.features,mem.query,mem.read,
#  mem.read8,mem.read16,mem.read32,rtc.now,ticks.since_boot,io.in,pci.scan,
#  pci.config.read,pci.config.read8,pci.config.read16,pci.config.read32,
#  pci.cap.list,pci.cap.read,pci.bars,pci.bar.read,pci.mem.read,
#  pci.mem.read8,pci.mem.read16,pci.mem.read32" - twenty-five primitives.
# Learn each one.

describe help
describe describe
describe cpu.vendor
describe cpu.features
describe mem.query
describe mem.read
describe mem.read8
describe mem.read16
describe mem.read32
describe rtc.now
describe ticks.since_boot
describe io.in
describe pci.scan
describe pci.config.read
describe pci.config.read8
describe pci.config.read16
describe pci.config.read32
describe pci.cap.list
describe pci.cap.read
describe pci.bars
describe pci.bar.read
describe pci.mem.read
describe pci.mem.read8
describe pci.mem.read16
describe pci.mem.read32

# Introspection says `pci.scan` exists; now use it once so the demo and CI
# both cover the newly-advertised primitive.
pci.scan

# At this point the model knows: the OS has twenty-five primitives, which ones
# take arguments and in what format, and what fields each response contains.
# io.in's schema even leaks its allowlist - the set of ports this machine
# will let the model touch - and `pci.scan`/`pci.config.read`/
# `mem.read32`/`pci.config.read32`/`pci.cap.list`/`pci.cap.read`/
# `pci.bars`/`pci.bar.read`/`pci.mem.read`/`pci.mem.read32` together confirm
# the machine can describe its bus topology, inspect config registers and
# capability chains, name each device's windows, and read bytes or typed
# values through low memory, config space, plus I/O and memory BARs from the
# inside.
# Everything learned without a manual.
